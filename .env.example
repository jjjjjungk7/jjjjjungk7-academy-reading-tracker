# Supabase project URL (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin PIN hash (bcrypt).
# Generate with: node -e "const b=require('bcryptjs'); b.hash('YOUR_PIN', 10).then(console.log)"
ADMIN_PIN_HASH=your-bcrypt-hash
